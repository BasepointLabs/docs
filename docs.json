{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Praxic Docs",
  "description": "Customer docs for Praxic AI employees, workflows, integrations, knowledge, and billing.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "assistant",
      "mcp",
      "add-mcp"
    ]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Support",
          "icon": "life-buoy",
          "href": "mailto:support@basepointlabs.com"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Get started",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "getting-started/quickstart",
          "concepts/core-concepts"
        ]
      },
      {
        "group": "Build",
        "icon": "bot",
        "expanded": true,
        "pages": [
          "build/ai-employees",
          "build/knowledge-bases",
          "build/skills",
          "build/workflows"
        ]
      },
      {
        "group": "Integrations",
        "icon": "plug",
        "expanded": true,
        "pages": [
          "integrations/overview",
          "channels/telegram",
          "integrations/composio"
        ]
      },
      {
        "group": "Operations",
        "icon": "inbox",
        "expanded": true,
        "pages": [
          "inbox/handoffs-bookings-tasks",
          "operations/activity-and-notifications",
          "billing/credits-and-plans",
          "troubleshooting/common-issues"
        ]
      },
      {
        "group": "API reference",
        "icon": "code-xml",
        "expanded": false,
        "pages": [
          "api-reference/authentication",
          "api-reference/endpoints",
          "api-reference/models-and-tools",
          "api-reference/workflow-reference"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Praxic",
      "href": "https://praxic.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/basepointlabs",
      "linkedin": "https://linkedin.com/company/basepointlabs"
    }
  }
}
